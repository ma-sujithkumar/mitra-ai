{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "session_id",
    "passed",
    "blocker_count",
    "warn_count",
    "checks"
  ],
  "properties": {
    "session_id": { "type": "string" },
    "passed": { "type": "boolean" },
    "blocker_count": { "type": "integer" },
    "warn_count": { "type": "integer" },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["key", "label", "status", "detail"],
        "properties": {
          "key": { "type": "string" },
          "label": { "type": "string" },
          "status": { "type": "string", "enum": ["pass", "warn", "fail"] },
          "detail": { "type": "string" },
          "warn_message": { "type": "string" }
        }
      }
    }
  }
}
