# MITRA Epic 1 LLM configuration.
# Copy this file to .env and fill in values for backend startup defaults.
# Per-run BYOM values entered in the UI override these values for that run only.

LLM_TYPE=anthropic
LLM_API_KEY=
LLM_MODEL=
LLM_GATEWAY_URL=

# Optional PEM bundle for local/corporate root CAs used by LLM HTTPS calls.
LLM_CA_BUNDLE=
