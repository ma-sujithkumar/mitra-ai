# Copy this file to .env and fill in your values.
# .env is gitignored and must NOT be committed.

# One of: openai | gemini | anthropic
LLM_TYPE=anthropic

# API key from your provider account
LLM_API_KEY=sk-ant-...

# Optional: LiteLLM proxy / company gateway URL
# Leave blank to use the provider default endpoint
LLM_GATEWAY_URL=
